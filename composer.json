{
    "name": "gauravgpil/php-video-automator",
    "description": "A standalone PHP library to automatically generate videos from text scripts using FFMPEG, AI images, and stock footage.",
    "type": "library",
    "keywords": ["video", "ffmpeg", "automation", "ai", "pixabay", "pexels", "wikimedia", "archive", "generator"],
    "license": "MIT",
    "authors": [
        {
            "name": "Gaurav Ghoghari",
            "email": "gaurav.ghoghari@hotmail.com"
        }
    ],
    "require": {
        "php": "^8.1",
        "php-ffmpeg/php-ffmpeg": "^1.2",
        "guzzlehttp/guzzle": "^7.8",
        "symfony/process": "^6.0|^7.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.5",
        "phpstan/phpstan": "^2.2"
    },
    "autoload": {
        "psr-4": {
            "PhpVideoAutomator\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "PhpVideoAutomator\\Tests\\": "tests/"
        }
    },
    "minimum-stability": "stable"
}
